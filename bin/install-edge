#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

echo "Pulling latest main..."
if ! git pull --ff-only origin main; then
  echo "Warning: git pull failed — installing from current local state." >&2
fi

echo "Installing obsidian-mcp from local source..."
cargo install --path . --features embeddings

echo "Done. Version: $(obsidian-mcp --version 2>/dev/null || echo 'unknown')"
